{
  "name": "@supermodel/design-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal orchestration service for SuperModel MVP flows.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
